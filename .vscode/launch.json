{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome: host-shell",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "webpack:/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Attach Chrome: host-shell",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
