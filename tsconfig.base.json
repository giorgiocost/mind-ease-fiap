{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@shared/ui": ["libs/shared/ui/src/index.ts"],
      "@shared/a11y": ["libs/shared/a11y/src/index.ts"],
      "@shared/data-access": ["libs/shared/data-access/src/index.ts"],
      "@shared/state": ["libs/shared/state/src/index.ts"],
      "@shared/utils": ["libs/shared/utils/src/index.ts"],
      "@shared/stores/*": ["libs/shared/state/src/lib/stores/*"],
      "@shared/guards/*": ["libs/shared/data-access/src/lib/guards/*"],
      "@shared/interceptors/*": [
        "libs/shared/data-access/src/lib/interceptors/*"
      ],
      "@shared/services/*": ["libs/shared/data-access/src/lib/services/*"],
      "@shared/models/*": ["libs/shared/data-access/src/lib/models/*"],
      "@shared/styles/*": ["libs/shared/ui/src/lib/styles/*"],
      "@shared/tokens": ["libs/shared/a11y/src/lib/tokens.ts"],
      "mfe-dashboard/Routes": [
        "apps/mfe-dashboard/src/app/remote-entry/entry.routes.ts"
      ],
      "mfe-tasks/Routes": ["apps/mfe-tasks/src/app/remote-entry/entry.routes.ts"],
      "mfe-profile/Routes": ["apps/mfe-profile/src/app/remote-entry/entry.routes.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
