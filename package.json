{
  "name": "@adhd-task-manager/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "start": "nx serve host-shell",
    "start:all": "nx run-many --target=serve --projects=host-shell,mfe-dashboard,mfe-tasks,mfe-profile --parallel=4",
    "build": "nx build host-shell",
    "build:all": "nx run-many --target=build --all --parallel=4",
    "test": "nx test",
    "test:all": "nx run-many --target=test --all",
    "test:ci": "nx run-many --target=test --all --parallel=3 --coverage",
    "lint": "nx lint",
    "lint:all": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all --fix",
    "format": "prettier --write \"**/*.{ts,js,json,scss,html,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,scss,html,md}\"",
    "affected:test": "nx affected --target=test",
    "affected:lint": "nx affected --target=lint",
    "affected:build": "nx affected --target=build",
    "graph": "nx graph",
    "reset": "nx reset",
    "e2e": "npx nx run host-shell-e2e:e2e",
    "e2e:ci": "npx nx run host-shell-e2e:e2e --args=\"--project=chromium\"",
    "e2e:ui": "npx nx run host-shell-e2e:e2e --args=\"--ui\"",
    "e2e:headed": "npx nx run host-shell-e2e:e2e --args=\"--headed\"",
    "e2e:debug": "npx nx run host-shell-e2e:e2e --args=\"--debug\"",
    "e2e:critical": "npx nx run host-shell-e2e:e2e --args=\"--grep=@critical\"",
    "e2e:smoke": "npx nx run host-shell-e2e:e2e --args=\"--grep=@smoke\"",
    "e2e:report": "npx playwright show-report apps/host-shell-e2e/playwright-report"
  },
  "private": true,
  "dependencies": {
    "@angular-devkit/build-angular": "~21.1.0",
    "@angular/cdk": "^21.2.1",
    "@angular/common": "~21.1.0",
    "@angular/compiler": "~21.1.0",
    "@angular/core": "~21.1.0",
    "@angular/forms": "~21.1.0",
    "@angular/platform-browser": "~21.1.0",
    "@angular/platform-browser-dynamic": "~21.1.0",
    "@angular/platform-server": "~21.1.0",
    "@angular/router": "~21.1.0",
    "@angular/ssr": "~21.1.0",
    "@nx/angular": "22.5.1",
    "express": "^4.21.2",
    "rxjs": "~7.8.0"
  },
  "devDependencies": {
    "@angular-devkit/core": "~21.1.0",
    "@angular-devkit/schematics": "~21.1.0",
    "@angular/build": "~21.1.0",
    "@angular/cli": "~21.1.0",
    "@angular/compiler-cli": "~21.1.0",
    "@angular/language-service": "~21.1.0",
    "@eslint/js": "^9.8.0",
    "@module-federation/enhanced": "^2.0.1",
    "@nx/devkit": "22.5.1",
    "@nx/eslint": "22.5.1",
    "@nx/eslint-plugin": "22.5.1",
    "@nx/jest": "22.5.1",
    "@nx/js": "22.5.1",
    "@nx/module-federation": "22.5.1",
    "@nx/playwright": "22.5.1",
    "@nx/web": "22.5.1",
    "@nx/webpack": "22.5.1",
    "@nx/workspace": "22.5.1",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~21.1.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^4.0.18",
    "angular-eslint": "^21.0.1",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "http-server": "^14.1.1",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.3.0",
    "jest-preset-angular": "~16.0.0",
    "jest-util": "^30.0.2",
    "jsdom": "^27.1.0",
    "nx": "22.5.1",
    "prettier": "~3.6.2",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vitest": "^4.0.8"
  }
}
