# ─────────────────────────────────────────────────────────────────────────────
# MindEase — Environment Variables Template
#
# Copy this file to .env and fill in the values for local development.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── General ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── API ──────────────────────────────────────────────────────────────────────
# Base URL for the backend REST API
API_URL=http://localhost:3000/api/v1

# ── Authentication ────────────────────────────────────────────────────────────
# Secret used to sign/verify JWT tokens (development only)
JWT_SECRET=your-local-secret-key-change-me

# ── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_ANALYTICS=false
ENABLE_SENTRY=false

# ── E2E / Playwright ─────────────────────────────────────────────────────────
# Base URL used by Playwright when running E2E tests
PLAYWRIGHT_BASE_URL=http://localhost:4200

# ── Vercel Deployment (CI/CD secrets — do NOT commit real values) ─────────────
# Generate at: https://vercel.com/account/tokens
VERCEL_TOKEN=

# Found in: Vercel project → Settings → General
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
